# Black Swan Hunter - Environment Configuration Template
# Copy this file to .env and fill in your credentials

# 1. Binance API (Read/Trade Access)
BINANCE_API_KEY=your_binance_key_here
BINANCE_API_SECRET=your_binance_secret_here

# 2. DingTalk Notification (Personal Alert Channel)
DINGTALK_TOKEN=your_dingtalk_token_here
DINGTALK_SECRET=your_dingtalk_secret_here

# 3. Model Configuration (OpenClaw Powered)
OPENCLAW_MODEL_ID=google/gemini-3-flash-preview

# 4. Path Configuration (Optional: for cross-device mount)
# Default path points to the skill directory
SWAN_DATA_DIR=./skills/black-swan-hunter/
